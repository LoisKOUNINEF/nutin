// override breakpoints used in mixins.respond-to()
$breakpoints: (
  xs: 475px,    // Small phones (iPhone SE, Galaxy Fold)
  sm: 640px,    // Tailwind's standard (larger phones)
  md: 768px,    // Bootstrap's tablet (iPad portrait)
  lg: 1024px,   // Tailwind's standard (iPad landscape, small laptops)
  xl: 1280px,   // Tailwind's standard (desktops)
  2xl: 1536px,  // Tailwind's 2xl (large desktops)
);
